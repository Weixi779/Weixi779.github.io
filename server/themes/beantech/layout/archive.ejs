---
layout: layout
---

<!-- Main Content -->
<div class="container">
    <div class="row">
        <div class="col-lg-8 col-lg-offset-2 col-md-10 col-md-offset-1">
            <div id="tag_cloud" class="tags tags-sup js-tags">
                <a class="tag-button tag-button--all" data-encode="">Show All <sup><%= site.posts.length %></sup></a>
                <% site.tags.sort('length').reverse().each(function(tag) { %>
                    <a class="tag-button"
                       data-encode="<%= encodeURIComponent(tag.name) %>"
                       href="<%= config.root %>archive/?tag=<%= encodeURIComponent(tag.name) %>"
                       title="<%= tag.name %>"
                       rel="<%= tag.length %>">
                        <%= tag.name %>
                        <sup><%= tag.length %></sup>
                    </a>
                <% }); %>
            </div>

            <div class="mini-post-list js-result">
                <% var postsByYear = {}; %>
                <% site.posts.sort('date').reverse().each(function(post) { %>
                    <% var year = post.date.format('YYYY'); %>
                    <% if (!postsByYear[year]) { postsByYear[year] = []; } %>
                    <% postsByYear[year].push(post); %>
                <% }); %>
                <% Object.keys(postsByYear).sort().reverse().forEach(function(year) { %>
                    <section class="archive-year-section">
                        <span class="fa listing-seperator">
                            <span class="tag-text"><%= year %></span>
                        </span>
                        <% postsByYear[year].forEach(function(post) { %>
                            <% var encodedTags = post.tags.map(function(tag){ return encodeURIComponent(tag.name); }).join(','); %>
                            <div class="post-preview item" data-tags="<%= encodedTags %>">
                                <a href="<%- config.root %><%- post.path %>">
                                    <h2 class="post-title"><%- post.title || "Untitled" %></h2>
                                    <% if (post.subtitle && post.subtitle.length) { %>
                                        <h3 class="post-subtitle"><%- post.subtitle %></h3>
                                    <% } %>
                                </a>
                                <hr>
                            </div>
                        <% }); %>
                    </section>
                <% }); %>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var params = new URLSearchParams(window.location.search);
        var activeTag = params.get('tag');
        var items = Array.prototype.slice.call(document.querySelectorAll('.mini-post-list .item'));
        var sections = Array.prototype.slice.call(document.querySelectorAll('.archive-year-section'));
        var buttons = Array.prototype.slice.call(document.querySelectorAll('.js-tags .tag-button'));

        function update(tag) {
            items.forEach(function (item) {
                if (!tag) {
                    item.style.display = '';
                    return;
                }
                var tags = item.getAttribute('data-tags') || '';
                item.style.display = tags.split(',').indexOf(tag) !== -1 ? '' : 'none';
            });

            sections.forEach(function (section) {
                var visible = Array.prototype.some.call(section.querySelectorAll('.item'), function (item) {
                    return item.style.display !== 'none';
                });
                section.style.display = visible ? '' : 'none';
            });

            buttons.forEach(function (button) {
                var tagValue = button.getAttribute('data-encode') || '';
                if ((tag || '') === tagValue) {
                    button.classList.add('focus');
                } else {
                    button.classList.remove('focus');
                }
            });
        }

        update(activeTag || '');
    })();
</script>
